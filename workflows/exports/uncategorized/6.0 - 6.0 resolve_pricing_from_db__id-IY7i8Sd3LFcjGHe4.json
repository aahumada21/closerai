                                   ],
                      "id":  "29646759-807a-41f9-b29c-3176f34869f1",
                      "name":  "get_pricing_from_db",
                      "credentials":  {
                                          "postgres":  {
                                                           "id":  "a9C9SXdbhsOBvUzF",
                                                           "name":  "Postgres account 2"
                                                       }
                                      }
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "function norm(value) {\n  return String(value || \"\")\n    .normalize(\"NFD\")\n    .replace(/[\\u0300-\\u036f]/g, \"\")\n    .toLowerCase()\n    .trim()\n    .replace(/\\s+/g, \"_\");\n}\n\nfunction canonicalService(value) {\n  const service = norm(value);\n\n  const map = {\n    // Premium / profundo\n    lavado_profundo: \"lavado_premium\",\n    profundo: \"lavado_premium\",\n    interior_full: \"lavado_premium\",\n    limpieza_completa: \"lavado_premium\",\n    completo: \"lavado_premium\",\n    lavado_completo: \"lavado_premium\",\n\n    // Básico / esencial / mantención\n    lavado_esencial: \"lavado_basico\",\n    esencial: \"lavado_basico\",\n    basico: \"lavado_basico\",\n    lavado_basico: \"lavado_basico\",\n    lavado_de_mantencion: \"lavado_basico\",\n    lavado_mantencion: \"lavado_basico\",\n    mantencion: \"lavado_basico\",\n    mantenimiento: \"lavado_basico\",\n\n    // Oficiales\n    lavado_premium: \"lavado_premium\",\n    encerado_full: \"encerado_full\",\n    encerado: \"encerado_full\"\n  };\n\n  return map[service] || service;\n}\n\nfunction canonicalVehicle(value) {\n  const vehicle = norm(value);\n\n  const map = {\n    suv: \"suv\",\n    jeep: \"suv\",\n    \"4x4\": \"suv\",\n\n    sedan: \"sedan\",\n    auto: \"sedan\",\n    automovil: \"sedan\",\n\n    camioneta: \"camioneta\",\n    pickup: \"camioneta\",\n    pick_up: \"camioneta\"\n  };\n\n  return map[vehicle] || vehicle;\n}\n\n// Soporta entrada directa o entrada anidada desde execution_context\nconst input =\n  $json.execution_context \u0026\u0026 typeof $json.execution_context === \"object\"\n    ? { ...$json.execution_context, ...$json }\n    : $json;\n\nconst service = canonicalService(\n  input.service_interest || input.service_code || input.service\n);\n\nconst vehicle = canonicalVehicle(\n  input.vehicle_type\n);\n\nconst district = norm(\n  input.district || input.district_key\n);\n\nif (!service || !vehicle || !district) {\n  throw new Error(\n    `Missing pricing inputs: service=${service || \"empty\"}, vehicle=${vehicle || \"empty\"}, district=${district || \"empty\"}`\n  );\n}\n\nreturn [\n  {\n    service_code: service,\n    vehicle_type: vehicle,\n    district_key: district,\n    original_inputs: {\n      service_interest: input.service_interest || null,\n      service_code: input.service_code || null,\n      vehicle_type: input.vehicle_type || null,\n      district: input.district || null,\n      district_key: input.district_key || null\n    },\n    normalized_inputs: {\n      service_code: service,\n      vehicle_type: vehicle,\n      district_key: district\n    }\n  }\n];"
                                     },
