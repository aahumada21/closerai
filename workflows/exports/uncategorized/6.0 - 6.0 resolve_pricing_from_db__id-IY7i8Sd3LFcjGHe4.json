    "nodes":  [
                  {
                      "parameters":  {
                                         "operation":  "executeQuery",
                                         "query":  "WITH input_values AS (\n  SELECT\n    \u0027{{ String($json.service_code || \"\").replace(/\u0027/g, \"\u0027\u0027\") }}\u0027::text AS service_code,\n    \u0027{{ String($json.vehicle_type || \"\").replace(/\u0027/g, \"\u0027\u0027\") }}\u0027::text AS vehicle_type,\n    \u0027{{ String($json.district_key || \"\").replace(/\u0027/g, \"\u0027\u0027\") }}\u0027::text AS district_key\n),\n\nactive_version AS (\n  SELECT id\n  FROM public.pricing_versions\n  WHERE is_active = true\n    AND valid_from \u003c= NOW()\n  ORDER BY valid_from DESC\n  LIMIT 1\n),\n\nbase_rule AS (\n  SELECT\n    p.pricing_version_id,\n    p.service_code,\n    p.vehicle_type,\n    p.base_price\n  FROM public.service_vehicle_prices p\n  JOIN active_version v\n    ON v.id = p.pricing_version_id\n  JOIN input_values i\n    ON replace(lower(trim(p.service_code)), \u0027 \u0027, \u0027_\u0027) = i.service_code\n   AND replace(lower(trim(p.vehicle_type)), \u0027 \u0027, \u0027_\u0027) = i.vehicle_type\n  WHERE p.is_active = true\n  LIMIT 1\n),\n\ndistrict_rule AS (\n  SELECT\n    d.district_key,\n    d.surcharge\n  FROM public.district_surcharges d\n  JOIN active_version v\n    ON v.id = d.pricing_version_id\n  JOIN input_values i\n    ON replace(lower(trim(d.district_key)), \u0027 \u0027, \u0027_\u0027) IN (i.district_key, \u0027*\u0027)\n  WHERE d.is_active = true\n  ORDER BY\n    CASE\n      WHEN replace(lower(trim(d.district_key)), \u0027 \u0027, \u0027_\u0027) = (SELECT district_key FROM input_values) THEN 0\n      ELSE 1\n    END\n  LIMIT 1\n)\n\nSELECT\n  CASE\n    WHEN b.base_price IS NOT NULL THEN true\n    ELSE false\n  END AS pricing_found,\n\n  i.service_code,\n  i.vehicle_type,\n  i.district_key,\n\n  b.pricing_version_id,\n  b.base_price,\n  COALESCE(d.surcharge, 0) AS surcharge,\n\n  CASE\n    WHEN b.base_price IS NOT NULL\n      THEN b.base_price + COALESCE(d.surcharge, 0)\n    ELSE NULL\n  END AS final_price\n\nFROM input_values i\nLEFT JOIN base_rule b\n  ON true\nLEFT JOIN district_rule d\n  ON true;",
                                         "options":  {

                                                     }
                                     },
                      "type":  "n8n-nodes-base.postgres",
                      "typeVersion":  2.6,
                      "position":  [
                                       688,
