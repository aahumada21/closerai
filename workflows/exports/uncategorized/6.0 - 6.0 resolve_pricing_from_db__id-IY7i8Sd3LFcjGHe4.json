                  {
                      "parameters":  {
                                         "jsCode":  "return [{\n  success: false,\n  pricing_found: false,\n  error_code: \"pricing_rule_not_found\",\n  details: {\n    service: $json.service_code || null,\n    vehicle_type: $json.vehicle_type || null,\n    district: $json.district_key || null,\n    base_price: $json.base_price || null,\n    final_price: $json.final_price || null\n  }\n}];"
