    "name":  "6.2 check_calendar_slot",
    "description":  null,
    "active":  true,
    "isArchived":  false,
    "nodes":  [
                  {
                      "parameters":  {
                                         "inputSource":  "jsonExample",
                                         "jsonExample":  "{\n  \"lead_id\": \"={{$json.execution_context.lead_id}}\",\n  \"booking_date\": \"={{$json.execution_context.booking_date}}\",\n  \"booking_time\": \"={{$json.execution_context.booking_time}}\",\n  \"slot_id\": \"={{$json.execution_context.slot_id}}\",\n  \"duration_minutes\": \"={{$json.execution_context.duration_minutes || 120}}\",\n  \"calendar_id\": \"={{$json.execution_context.calendar_id || \u0027primary\u0027}}\"\n}"
                                     },
                      "id":  "c055762a-8fe7-4141-a639-df2372f30060",
                      "typeVersion":  1.1,
                      "name":  "When Executed by Another Workflow",
                      "type":  "n8n-nodes-base.executeWorkflowTrigger",
                      "position":  [
                                       272,
                                       352
                                   ]
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const {\n  lead_id,\n  booking_date,\n  booking_time,\n  slot_id,\n  duration_minutes,\n  calendar_id,\n  timezone,\n} = $json;\n\nif (!booking_date || !booking_time || !slot_id) {\n  throw new Error(\u0027Faltan datos requeridos: booking_date, booking_time o slot_id\u0027);\n}\n\nconst zone = timezone || \u0027America/Santiago\u0027;\nconst duration = Number(duration_minutes || 120);\n\nif (Number.isNaN(duration) || duration \u003c= 0) {\n  throw new Error(\u0027duration_minutes inválido\u0027);\n}\n\nconst start = DateTime.fromISO(`${booking_date}T${booking_time}`, { zone });\n\nif (!start.isValid) {\n  throw new Error(`Fecha/hora inválida: ${start.invalidExplanation || \u0027sin detalle\u0027}`);\n}\n\nconst end = start.plus({ minutes: duration });\n\nreturn [\n  {\n    json: {\n      lead_id: lead_id || null,\n      booking_date,\n      booking_time,\n      slot_id,\n      duration_minutes: duration,\n      calendar_id: calendar_id || \u0027primary\u0027,\n      timezone: zone,\n\n      slot_start_at: start.toUTC().toISO(),\n      slot_end_at: end.toUTC().toISO(),\n\n      slot_start_local: start.toISO(),\n      slot_end_local: end.toISO(),\n    }\n  }\n];"
                                     },
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       480,
                                       352
                                   ],
                      "id":  "63cf8e40-b806-454d-8580-29f6b92f545f",
                      "name":  "build_slot_range"
                  },
                  {
                      "parameters":  {
                                         "operation":  "getAll",
                                         "calendar":  {
                                                          "__rl":  true,
                                                          "value":  "={{ $json.calendar_id }}",
                                                          "mode":  "id"
                                                      },
                                         "returnAll":  true,
                                         "timeMin":  "={{ $json.slot_start_at }}",
                                         "timeMax":  "={{ $json.slot_end_at }}",
                                         "options":  {
                                                         "fields":  "items(id,summary,start,end,status,htmlLink),nextPageToken"
                                                     }
                                     },
                      "type":  "n8n-nodes-base.googleCalendar",
                      "typeVersion":  1.3,
                      "position":  [
                                       688,
                                       352
                                   ],
                      "id":  "c69f653f-974c-41ed-b575-65c4f447a431",
                      "name":  "Get many events",
                      "alwaysOutputData":  true,
                      "credentials":  {
                                          "googleCalendarOAuth2Api":  {
                                                                          "id":  "mpmI0f0dGSSsN1Rj",
                                                                          "name":  "Google Calendar account"
                                                                      }
                                      }
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const slotContext = $items(\"build_slot_range\", 0, 0)[0].json;\nconst calendarItems = $input.all();\n\n// Filtramos solo items que realmente sean eventos\nconst realEvents = calendarItems.filter(item =\u003e {\n  const j = item.json || {};\n  return !!j.id;\n});\n\nconst hasEvents = realEvents.length \u003e 0;\n\nreturn [{\n  booking_date: slotContext.booking_date,\n  booking_time: slotContext.booking_time,\n  slot_id: slotContext.slot_id || null,\n  calendar_id: slotContext.calendar_id || \"primary\",\n  duration_minutes: slotContext.duration_minutes || 120,\n  slot_start_at: slotContext.slot_start_at,\n  slot_end_at: slotContext.slot_end_at,\n  slot_available: !hasEvents,\n  conflicting_events_count: realEvents.length,\n  conflicting_events: realEvents.map(item =\u003e ({\n    id: item.json.id || null,\n    summary: item.json.summary || null,\n    start: item.json.start || null,\n    end: item.json.end || null\n  }))\n}];"
                                     },
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       896,
                                       352
                                   ],
                      "id":  "7c1cba81-31a9-45e7-a8cf-df6638113c25",
                      "name":  "normalize_slot_check"
                  }
              ],
