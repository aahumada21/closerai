                      "parameters":  {
                                         "jsCode":  "return [{\n  ...$json,\n  message_to_send: \"No pude calcular la cotización en este momento. Lo revisaré y te ayudo enseguida.\",\n  db_operations: [\"messages\"],\n  state_update: {\n    ...($json.state_update || {}),\n    last_bot_action: \"pricing_rule_not_found\",\n    next_goal: \"manual_pricing_review\"\n  },\n  notes: [\n    ...($json.notes || []),\n    \"pricing_rule_not_found\"\n  ]\n}];"
