                                         "jsonExample":  "{\n  \"lead_id\": \"={{ $json.lead_id }}\",\n  \"channel\": \"={{ $json.channel }}\",\n  \"phone\": \"={{ $json.phone }}\",\n  \"calendar_id\": \"={{ $json.calendar_id }}\",\n  \"service_interest\": \"={{ $json.service_interest }}\",\n  \"vehicle_type\": \"={{ $json.vehicle_type }}\",\n  \"district\": \"={{ $json.district }}\",\n  \"booking_date\": \"={{ $json.booking_date }}\",\n  \"booking_time\": \"={{ $json.booking_time }}\",\n  \"slot_id\": \"={{ $json.slot_id }}\",\n  \"service_address\": \"={{ $json.service_address }}\",\n  \"address_reference\": \"={{ $json.address_reference }}\",\n  \"eta_minutes\": \"={{ $json.eta_minutes }}\",\n  \"execution_context\": \"={{ JSON.stringify($json.execution_context || {}) }}\",\n  \"context_packet\": \"={{ JSON.stringify($json.context_packet || {}) }}\",\n  \"decision\": \"={{ JSON.stringify($json.decision || {}) }}\",\n  \"state_update\": \"={{ JSON.stringify($json.state_update || {}) }}\",\n  \"execution_meta\": \"={{ JSON.stringify($json.execution_meta || {}) }}\"\n}"
                                     },
                      "id":  "c055762a-8fe7-4141-a639-df2372f30060",
