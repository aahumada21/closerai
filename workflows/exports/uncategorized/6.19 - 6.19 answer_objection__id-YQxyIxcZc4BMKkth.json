                                       224,
                                       0
                                   ]
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const msg = (\n  $json.execution_context?.message ||\n  $json.decision?.message ||\n  \"\"\n).trim();\n\nconst isWillThink = (() =\u003e {\n  const t = String($json.context_packet?.conversation?.latest_user_message || \"\").toLowerCase();\n  return t.includes(\"lo voy a pensar\") || t.includes(\"lo pensare\") || t.includes(\"lo pensar\") || t.includes(\"despues veo\") || t.includes(\"después veo\");\n})();\n\nconst fallback = isWillThink\n  ? \"Perfecto, tómate tu tiempo. Cualquier cosa me dices y te ayudo feliz. Si te parece, puedo enviarte los horarios disponibles o agendar cuando te acomode. ¿Qué prefieres?\"\n  : \"Perfecto. Cualquier cosa me dices y te ayudo feliz. ¿Qué te gustaría revisar?\";\n\nreturn [\n  {\n    json: {\n      ...$json,\n      message_to_send: msg || fallback,\n      db_operations: [\"messages\", \"lead_state\"],\n      state_update: {\n        ...($json.execution_context?.state_update || {}),\n        stage: \"closing\",\n        intent_last: \"objection_answered\",\n        next_goal: \"book_appointment\",\n        last_bot_action: \"answer_objection\",\n        missing_fields: []\n      }\n    }\n  }\n];"
                                     },
