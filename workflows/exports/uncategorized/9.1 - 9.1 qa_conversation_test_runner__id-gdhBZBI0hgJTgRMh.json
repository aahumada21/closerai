                  {
                      "parameters":  {
                                         "jsCode":  "const runStamp = String(Date.now()).slice(-4);\n\nreturn items.map((item, index) =\u003e {\n  const scenario = item.json;\n\n  const scenarioNumber = String(index + 1).padStart(3, \"0\");\n  const qaPhone = `56901${runStamp}${scenarioNumber}`;\n\n  let steps = scenario.steps;\n\n  if (typeof steps === \"string\") {\n    try {\n      steps = JSON.parse(steps);\n    } catch {\n      steps = [];\n    }\n  }\n\n  if (!Array.isArray(steps)) {\n    steps = [];\n  }\n\n  return {\n    json: {\n      id: scenario.id,\n      name: scenario.name,\n      suite: scenario.suite,\n      priority: scenario.priority,\n      tags: scenario.tags || [],\n      steps,\n      phone: qaPhone,\n      run_id: `qa_${new Date().toISOString()}_${scenario.id}`,\n    },\n  };\n});"
                                     },
